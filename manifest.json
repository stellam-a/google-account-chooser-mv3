{
  "manifest_version": 3,
  "name": "Google Account Chooser",
  "short_name": "Account Chooser",
  "version": "1.0.1",
  "description": "A simple extension to choose Google accounts per tab.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "*://accounts.google.com/*"
  ],
  "icons": {
    "16": "logo16.png",
    "24": "logo24.png",
    "32": "logo32.png",
    "48": "logo48.png",
    "64": "logo64.png",
    "128": "logo128.png"
  }
}
